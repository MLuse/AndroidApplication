    <style name="SplashScreenTheme" parent="Theme.JokesApp">
        <item name="android:textSize">@dimen/_50sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
